{
  "name": "retro-system-monitoring-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev --hostname 0.0.0.0\" \"node --env-file=.env.local server/index.js\"",
    "dev:web": "next dev --hostname 0.0.0.0",
    "dev:api": "node --env-file=.env.local server/index.js",
    "agent": "node --env-file=.env.local agent/index.js",
    "build": "next build",
    "build:pages": "next build",
    "start": "concurrently \"next start --hostname 0.0.0.0\" \"node --env-file=.env.local server/index.js\"",
    "remote": "npm run build && npm run start",
    "lint": "next lint"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "express": "^4.18.3",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2"
  }
}
