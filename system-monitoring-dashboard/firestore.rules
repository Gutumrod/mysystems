rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null && request.auth.uid == "REPLACE_WITH_YOUR_FIREBASE_AUTH_UID";
    }

    match /devices/{deviceId}/status/current {
      allow read: if isOwner();
      allow write: if false;
    }

    match /devices/{deviceId}/commands/{commandId} {
      allow create: if isOwner();
      allow read, update, delete: if false;
    }
  }
}
