# ==============================================================================
# shop-frontend — Production Environment Variables
# ไฟล์นี้เป็นตัวอย่างค่า environment variables สำหรับ production
# ห้ามใส่ค่าจริงในไฟล์นี้ — ไฟล์นี้ commit ได้
# ค่าจริงให้ตั้งใน Vercel Project Settings → Environment Variables
# ==============================================================================

# URL ของ Supabase project
# ดูได้จาก: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key ของ Supabase (ปลอดภัยที่จะ expose ฝั่ง client)
# ดูได้จาก: Supabase Dashboard → Project Settings → API → anon (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# UUID ของร้าน fallback สำหรับ:
# - local development
# - Vercel preview deployments (*.vercel.app)
# - production base domain เช่น booking.craftbikelab.com
#
# เมื่อเข้าแบบ tenant subdomain:
#   bangkok-bike-care.booking.craftbikelab.com
# middleware.ts จะอ่าน slug = "bangkok-bike-care" แล้ว query ร้านจาก DB โดยตรง
#
# แต่ถ้าเข้าแบบ:
# - booking.craftbikelab.com
# - craftbikelab-booking.vercel.app
# ระบบจะไม่มี tenant slug และจะ fallback มาที่ NEXT_PUBLIC_SHOP_ID ตัวนี้
#
# ดูได้โดยรัน SQL ใน Supabase SQL Editor:
#   SELECT id, slug, name FROM bike_booking.shops;
NEXT_PUBLIC_SHOP_ID=
